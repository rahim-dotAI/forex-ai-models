# Git LFS + Attributes — Trade Beacon v2.1.5-FINBERT
# =====================================================

# ── Git LFS ──────────────────────────────────────────
# Note: *.pkl is also in .gitignore so this rule never fires in practice.
# Kept here in case .gitignore is relaxed for specific pkl exports.
*.pkl filter=lfs diff=lfs merge=lfs -text
*.pkl merge=ours

# ── Python ───────────────────────────────────────────
*.py   text eol=lf
*.pyw  text eol=lf

# ── Config / Data ─────────────────────────────────────
*.json text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.toml text eol=lf
*.ini  text eol=lf
*.cfg  text eol=lf

# Trade Beacon runtime state files (written by GitHub Actions on Linux)
# Explicit eol=lf prevents CRLF corruption if opened on Windows
signal_state/*.json text eol=lf
signals.csv         text eol=lf
config.json         text eol=lf
config.runtime.base.json text eol=lf

# ── Docs / Markdown ───────────────────────────────────
*.md   text eol=lf
*.txt  text eol=lf
*.rst  text eol=lf

# ── Shell / CI ────────────────────────────────────────
*.sh   text eol=lf
*.bash text eol=lf

# ── Logs ─────────────────────────────────────────────
*.log  text eol=lf

# ── Fallback ─────────────────────────────────────────
# Auto-detect everything else; let Git decide text vs binary
*      text=auto
